# Large Data (Optional, but common for research projects)
# *.pdf
# *.png
# *.jpg
# *.jpeg

# Keep assets specifically used in theses
!theses/**/assets/

# Ingest inbox — local-only drop zone for files the user wants analysed or
# routed into a thesis. Agent consumes / moves to theses/<slug>/assets/.
# See agents/reference/ingest-workflow.md.
ingest/*
!ingest/.gitkeep

# MCP client config — contains PortDive access tokens; never commit.
.mcp.json

# Local script outputs
scripts/outputs/

